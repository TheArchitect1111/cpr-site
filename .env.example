# CPR Site — required environment variables
# Copy to .env.local for local development. Set all required (*) vars in Vercel Production.

# --- Required for production (*) ---

# Airtable personal access token with read/write on the CPR base
AIRTABLE_TOKEN=

# CPR Airtable base (defaults to production base if unset)
AIRTABLE_BASE_ID=appvVr6MVrJvEY0YJ
AIRTABLE_TABLE_ID=tblZwrZHi3WBR3NHZ

# HMAC secret for athlete/parent portal sessions (generate: openssl rand -hex 32)
PORTAL_SECRET=

# Resend API key — application confirmations, enrollments, admin alerts
RESEND_API_KEY=

# Verified sender in Resend (domain must be verified)
RESEND_FROM_EMAIL=Canadian Prospects Recruitment <mikecprglobal@mississaugamagic.com>

# Canonical public URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://cpr-site.vercel.app

# Vercel Blob — apply photo uploads and profile document uploads
BLOB_READ_WRITE_TOKEN=

# Admin session + create-client nonce (generate strong random values)
ADMIN_AUTH_SECRET=
ADMIN_PASSWORD=
ADMIN_EMAIL=mikecprglobal@mississaugamagic.com

# --- Recommended automations ---

# Make.com — new application webhook (optional; in-app Resend also sends apply emails)
MAKE_CPR_WEBHOOK=

# Make.com — new client enrollment webhook (replaces hardcoded URL)
CPR_ENROLL_WEBHOOK_URL=

# --- Optional ---

# Legacy admin login fallback (prefer AIRTABLE_ADMIN_USERS_TABLE_ID + ADMIN_USERS JSON)
ADMIN_USER=cpr
ADMIN_USERS=

# Airtable table overrides
AIRTABLE_ATHLETES_TABLE_ID=tblZwrZHi3WBR3NHZ
AIRTABLE_COACHES_TABLE_ID=
AIRTABLE_ADMIN_USERS_TABLE_ID=
AIRTABLE_ARCHIVE_TABLE_ID=

# Athlete profile edit tokens + coach share links
ATHLETE_ACCESS_SECRET=
COACH_SHARE_SECRET=

# Stripe (fee payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=CAD

# Resend inbound webhook
RESEND_WEBHOOK_SECRET=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=

# Explicit demo/sample data in production (never set on paying-client deploys)
DEMO_MODE=
